# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/proposal_intel
JOB_RETENTION_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=sk-...
PROPOSAL_MODEL=gpt-4o
PROPOSAL_MAX_TOKENS=500
PROPOSAL_TEMPERATURE=0.7
OPENAI_API_RATE_LIMIT=60

# Upwork (OAuth token after completing OAuth flow)
UPWORK_API_KEY=
UPWORK_API_SECRET=
UPWORK_API_RATE_LIMIT=20

# Freelancer (get from developers.freelancer.com)
FREELANCER_API_KEY=
FREELANCER_API_RATE_LIMIT=10

# PeoplePerHour
PPH_API_KEY=

# Scheduler
AGGREGATION_INTERVAL_SECONDS=300

# Job filtering
MIN_BUDGET_USD=50
MAX_BUDGET_USD=50000
MIN_CLIENT_RATING=4.0
MIN_CLIENT_JOBS_POSTED=3

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
